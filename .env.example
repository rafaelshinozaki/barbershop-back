PORT=3020

# Frontend URL - usado para CORS e links de convite
FRONTEND_URL=http://localhost:5173

# Stripe - substitua pelas suas chaves em https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_test_sua_chave_aqui
STRIPE_SECRET_KEY=sk_test_sua_chave_aqui
STRIPE_WEBHOOK_SECRET=whsec_sua_chave_aqui

DATABASE_URL="postgresql://user:password@localhost:5432/barbershop"
DB_DIALECT=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=root
DB_PASSWORD=sua_senha
DB_NAME=barbershop

# Email / Mailgun - substitua pelas suas credenciais em https://www.mailgun.com/
EMAIL_HOST=seu_email@gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=api@seudominio.org
EMAIL_PASS=sua_senha
MAILGUN_KEY=sua_mailgun_key
MAILGUN_API_KEY=sua_mailgun_api_key
MAILGUN_DOMAIN=sandboxxxxx.mailgun.org
MAILGUN_FROM=postmaster@sandboxxxxx.mailgun.org
EMAIL_FROM=postmaster@sandboxxxxx.mailgun.org

# PayPal - substitua pelas suas credenciais
PAYPAL_CLIENT_ID=seu_paypal_client_id
PAYPAL_CLIENT_SECRET=seu_paypal_client_secret
PAYPAL_MODE=sandbox

# Sessão e JWT
SESSION_SECRET=gere_uma_chave_secreta_aleatoria
SESSION_MAX_AGE=36000
JWT_SECRET=gere_uma_chave_secreta_aleatoria
JWT_EXPIRATION=3600

# Google OAuth - substitua em https://console.cloud.google.com/
GOOGLE_CLIENT_ID=seu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3020/auth/google/redirect

# Facebook OAuth
FACEBOOK_CLIENT_ID=seu_facebook_client_id
FACEBOOK_CLIENT_SECRET=seu_facebook_client_secret
FACEBOOK_CALLBACK_URL=http://localhost:3020/auth/facebook/redirect
DISABLE_SOCIAL_SSO=false

# AWS S3 - substitua pelas suas credenciais
AWS_ACCESS_KEY_ID=sua_aws_access_key
AWS_SECRET_ACCESS_KEY=sua_aws_secret_key
AWS_REGION=us-east-2
S3_BUCKET=nome-do-seu-bucket
