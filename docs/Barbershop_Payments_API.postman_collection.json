							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.expect(pm.response.code).to.eql(200);",
									"});",
									"",
									"pm.test('Response has data field', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('data');",
									"});",
									"",
									"pm.test('getAllPlans returns array', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data.getAllPlans).to.be.an('array');",
									"});",
									"",
									"// Extract first plan ID for later use",
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.getAllPlans && jsonData.data.getAllPlans.length > 0) {",
									"    pm.collectionVariables.set('planId', jsonData.data.getAllPlans[0].id);",
