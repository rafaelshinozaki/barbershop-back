			"name": "1. Authentication",
			"item": [
				{
					"name": "Login (Get JWT Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200 or 201', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
									"});",
									"",
									"pm.test('Response has success field', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('success');",
									"});",
									"",
									"// Extract token from cookies",
									"var cookies = pm.response.headers.get('Set-Cookie');",
									"if (cookies) {",
									"    var authMatch = cookies.match(/Authentication=([^;]+)/);",
									"    if (authMatch) {",
									"        pm.collectionVariables.set('authToken', authMatch[1]);",
									"        console.log('JWT Token extracted from cookie:', authMatch[1].substring(0, 50) + '...');",
									"    }",
									"}",
									"",
									"// Extract user data",
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.id) {",
									"    pm.collectionVariables.set('userId', jsonData.data.id);",
									"    console.log('User ID extracted:', jsonData.data.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"rafael.lima@barbershop.com\",\n  \"password\": \"pwned\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"login"
							]
						},
						"description": "Login to get JWT token for authenticated requests"
					}
				}
			]
		},
